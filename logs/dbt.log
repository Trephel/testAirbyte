create or replace transient table AIRBYTE_DATABASE.AIRBYTE_SCHEMA_intermediate.int_car_features
         as
        (

SELECT
    source_id,
    city,
    sector,
    brand,
    model,
    model_year_raw as model_year,
    
    -- Kilométrage temporairement désactivé
    NULL as mileage_km,
    
    fuel_type,
    transmission,
    price_dh,
    
    -- Calcul de l'âge du véhicule
    CASE 
        WHEN model_year_raw IS NOT NULL 
        THEN EXTRACT(YEAR FROM CURRENT_DATE()) - model_year_raw 
        ELSE NULL 
    END as car_age_years
    
FROM AIRBYTE_DATABASE.AIRBYTE_SCHEMA_staging.stg_avito_cars
WHERE price_dh IS NOT NULL
  AND brand IS NOT NULL
        );
